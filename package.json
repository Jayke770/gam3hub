{
  "name": "gamehub",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "build:itch": "turbo build:itch && (cd apps/web/out && mv _next next && grep -rl '_next' . | xargs sed -i '' 's/_next/next/g' && zip -r ../../../itch-tanks.zip .)",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "shadcn": "^4.6.0",
    "turbo": "^2.8.17",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "swr": "^2.4.1"
  }
}